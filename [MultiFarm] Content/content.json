{
  "Format": "2.9.0",

  // ── Custom hub locations ──────────────────────────────────────────────────
  // CP registers these as real GameLocations in Game1.locations automatically.
  // Names must use Custom_ prefix per CP requirements.
  // Warp redirects (Backwoods/Forest/Farm) are handled by the C# mod's
  // OnAssetRequested handler since CP TextOperations can't replace multi-token
  // warp groups (e.g. "Farm 40 0" → "Custom_MultiFarm_Hub_Backwoods 11 2").
  "CustomLocations": [
    { "Name": "Custom_MultiFarm_Hub_Farm",      "FromMapFile": "assets/maps/Custom_MultiFarm_Hub_Farm.tmx" },
    { "Name": "Custom_MultiFarm_Hub_Backwoods", "FromMapFile": "assets/maps/Custom_MultiFarm_Hub_Backwoods.tmx" },
    { "Name": "Custom_MultiFarm_Hub_Forest",    "FromMapFile": "assets/maps/Custom_MultiFarm_Hub_Forest.tmx" }
  ],

  "Changes": [

    // ── Farm type selector ────────────────────────────────────────────────────
    // Remove all non-Standard farm types from the new-game farm picker.
    // Each player chooses their own farm layout via the in-game MultiFarm menu;
    // the vanilla selector is only used for the host's slot-1 (vanilla Farm).
    // Keeping only "Standard" means the host clicks one option and continues.
    {
      "Action": "EditData",
      "Target": "Data/Farms",
      "Entries": {
        "1": null,
        "2": null,
        "3": null,
        "4": null,
        "5": null,
        "6": null
      }
    }

  ]
}
